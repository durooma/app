# Copy to .env and adjust. Used by docker-compose.
POSTGRES_PASSWORD=change-me
HTTP_PORT=8080
BASE_CURRENCY=CHF

# AI categorization. AI_PROVIDER: gemini | none
AI_PROVIDER=gemini
AI_MODEL=gemini-3.1-flash-lite
AI_API_KEY=

# For local (non-docker) runs, the app defaults to:
# DATABASE_URL=postgres://durooma:durooma@localhost:5432/durooma?sslmode=disable
